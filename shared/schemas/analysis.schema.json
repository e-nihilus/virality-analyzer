{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AnalysisResult",
  "description": "Aurea Viral Intelligence — Analysis result contract (MVP)",
  "type": "object",
  "required": ["id", "status"],
  "properties": {
    "id": { "type": "string" },
    "status": { "type": "string", "enum": ["pending", "processing", "completed", "failed"] },
    "analysis_source": { "type": "string", "enum": ["demo_mock", "uploaded_real", "uploaded_partial", "failed"] },
    "provider_status": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "provider", "status", "is_ai"],
        "properties": {
          "name": { "type": "string" },
          "provider": { "type": "string" },
          "status": { "type": "string", "enum": ["used", "fallback", "disabled", "failed"] },
          "is_ai": { "type": "boolean" },
          "message": { "type": "string" }
        }
      }
    },
    "metric_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["metric", "source_type"],
        "properties": {
          "metric": { "type": "string" },
          "source_type": { "type": "string", "enum": ["ai", "derived", "heuristic", "mock", "unavailable"] },
          "providers": { "type": "array", "items": { "type": "string" } },
          "message": { "type": "string" }
        }
      }
    },
    "progress": { "type": "number", "minimum": 0, "maximum": 1 },
    "video": {
      "type": "object",
      "properties": {
        "filename": { "type": "string" },
        "duration_seconds": { "type": "number" },
        "fps": { "type": "number" },
        "width": { "type": "integer" },
        "height": { "type": "integer" }
      },
      "required": ["filename"]
    },
    "overall_virality_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "retention_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "rewatch_factor": { "type": ["number", "null"] },
    "action_recognition_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "hook_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "hook_evidence": {
      "type": ["object", "null"],
      "properties": {
        "person_detected_first_5s": { "type": "boolean" },
        "face_arousal_avg_first_5s": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "text_hook_first_5s": {
          "type": ["object", "null"],
          "properties": {
            "text": { "type": "string" },
            "hook_type": { "type": "string" },
            "timestamp": { "type": "number" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "audio_energy_first_5s": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "pacing_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "dominant_emotion": { "type": ["string", "null"] },
    "emotion_intensity": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "attention_duration_seconds": { "type": ["number", "null"], "minimum": 0 },
    "timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["time_seconds"],
        "properties": {
          "time_seconds": { "type": "number" },
          "virality": { "type": "number", "minimum": 0, "maximum": 1 },
          "valence": { "type": "number", "minimum": 0, "maximum": 1 },
          "arousal": { "type": "number", "minimum": 0, "maximum": 1 },
          "emotion": { "type": "string" },
          "emotion_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "retention": { "type": "number", "minimum": 0, "maximum": 1 },
          "label": { "type": "string" }
        }
      }
    },
    "top_clips": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["start_seconds", "end_seconds", "score"],
        "properties": {
          "start_seconds": { "type": "number" },
          "end_seconds": { "type": "number" },
          "score": { "type": "number", "minimum": 0, "maximum": 1 },
          "predicted_retention": { "type": "number", "minimum": 0, "maximum": 1 },
          "reasons": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "insights": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "description", "severity"],
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "severity": { "type": "string", "enum": ["high", "medium", "low"] }
        }
      }
    }
  }
}
